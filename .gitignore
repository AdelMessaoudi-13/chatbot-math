# .gitignore pour le projet Chatbot Mathématiques

# Ignorer les dossiers et fichiers générés par Python
__pycache__/
*.py[cod]

# Ignorer les environnements virtuels
venv/
.env/

# Fichiers de logs
*.log

# Fichiers de dépendances installées
pip-log.txt
dist/
build/

# Ignorer les fichiers de configuration de l'IDE
.vscode/
.idea/
*.swp

# Fichiers spécifiques à macOS
.DS_Store

# Ignorer les fichiers temporaires de Gradio
gradio_cache/

# Ignorer les modèles téléchargés avec Ollama
~/.ollama/
~/.ollama/models/

# Ignorer les fichiers de sortie générés
output/
*.out
*.tmp

__pycache__/
.DS_Store

